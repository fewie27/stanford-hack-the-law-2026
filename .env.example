# Evidence Locker API — public origin only: scheme + host (no path). Port 443 is implied for https.
#
# Correct (API on its own host):
#   EVIDENCE_API_BASE_URL=https://api-evidence.example.com
#   EVIDENCE_API_BASE_URL=api-evidence.example.com
#
# Wrong (do not paste the UI site in front of the API hostname):
#   https://hacklaw.example.com/api-evidence.example.com
#
# Baked in at web build time — rebuild the web image after changing.
# Leave empty for local Expo dev (uses http://localhost:8000).
EVIDENCE_API_BASE_URL=

- name: Run classifier.py
  run: python backend/classifier/classifier.py
  env:
    API_KEY: ${{ secrets.GEMINI_API_KEY }}
