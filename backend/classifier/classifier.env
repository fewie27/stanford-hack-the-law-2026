# Evidence Locker API (FastAPI) base URL — scheme + host, no trailing slash.
# Leave empty for local development: the app uses http://localhost:8000 only.
# When set (e.g. deployed server), requests use this origin and never localhost:8000.

- name: Run classifier.py
  run: python backend/classifier/classifier.py
  env:
    API_KEY: ${{ secrets.GEMINI_API_KEY }}
